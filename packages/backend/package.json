{
  "name": "@ai-playlist/backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec node --loader ts-node/esm src/server.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.113.0",
    "@google-cloud/firestore": "8.7.0",
    "@google-cloud/secret-manager": "6.3.0",
    "axios": "1.18.1",
    "express": "5.2.1",
    "jsonwebtoken": "9.0.3",
    "uuid": "14.0.1"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "26.1.1",
    "@types/uuid": "11.0.0",
    "@vitest/coverage-v8": "4.1.10",
    "fast-check": "4.9.0",
    "nodemon": "3.1.14",
    "ts-node": "10.9.2",
    "vitest": "4.1.10"
  }
}
